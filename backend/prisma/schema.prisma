generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ============================================
// ORGANIZATION (Multi-Tenant Root)
// ============================================

model Organization {
  id   String @id @default(uuid())
  name String
  slug String @unique

  plan            Plan    @default(FREE)
  subscription_plan_id String?
  subscription_plan    SubscriptionPlan? @relation("OrgSubscriptionPlan", fields: [subscription_plan_id], references: [id])
  subscription_status  SubscriptionStatus @default(TRIAL)
  subscription_expires_at DateTime?
  wa_api_base_url String?
  wa_api_key      String? @db.Text
  wa_organization_id String?

  max_users              Int @default(3)
  max_contacts           Int @default(500)
  max_broadcasts_per_month Int @default(10)

  settings Json?

  is_active     Boolean   @default(true)
  trial_ends_at DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  users          User[]
  teams          Team[]
  wa_instances   WAInstance[]
  contacts       Contact[]
  tags           Tag[]
  conversations  Conversation[]
  broadcasts     Broadcast[]
  templates      MessageTemplate[]
  automations    Automation[]
  webhook_configs WebhookConfig[]
  deals          Deal[]
  activity_logs  ActivityLog[]
  scheduled_messages ScheduledMessage[]
  auto_responses     AutoResponse[]
  invoices           Invoice[]
  quick_replies      QuickReply[]
  csat_settings      CSATSetting?
  sla_settings       SlaSetting?
  holidays           Holiday[]
  internal_chats     InternalChat[]
  tracked_links      TrackedLink[]
  receipts           Receipt[]
  receipt_config     Json?
  tasks              Task[]

  @@map("organizations")
}

enum Plan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

// ============================================
// SUBSCRIPTION PLAN (DB-driven plan config)
// ============================================

model SubscriptionPlan {
  id          String  @id @default(uuid())
  plan_code   Plan    @unique
  name        String
  description String? @db.Text
  price       Int     @default(0)           // harga dalam rupiah, 0 = gratis
  billing_cycle String @default("monthly")  // monthly | yearly | lifetime

  // Resource quotas (-1 = unlimited)
  max_users                 Int @default(1)
  max_contacts              Int @default(100)
  max_wa_instances          Int @default(1)
  max_templates             Int @default(5)
  max_broadcasts_per_month  Int @default(0)
  max_recipients_per_broadcast Int @default(0)
  max_scheduled_messages    Int @default(0)
  max_deals                 Int @default(0)
  max_tags                  Int @default(3)
  max_webhook_configs       Int @default(0)
  daily_message_limit       Int @default(50)
  max_import_batch_size     Int @default(0)
  max_storage_mb            Int @default(100)
  analytics_max_days        Int @default(7)

  // Feature flags stored as JSON
  features    Json

  is_active   Boolean  @default(true)
  sort_order  Int      @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  invoices   Invoice[]
  subscribed_organizations Organization[] @relation("OrgSubscriptionPlan")

  @@map("subscription_plans")
}

// ============================================
// PAYMENT CONFIG (Global: bank accounts + Midtrans)
// ============================================

model BankAccount {
  id          String  @id @default(uuid())
  bank_name   String                       // BCA, BNI, Mandiri, etc.
  account_number String
  account_holder String                     // Nama pemilik rekening
  is_active   Boolean @default(true)
  sort_order  Int     @default(0)

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("bank_accounts")
}

model PaymentConfig {
  id    String @id @default(uuid())
  key   String @unique                     // e.g. midtrans_server_key, midtrans_client_key, midtrans_environment
  value String @db.Text
  label String?                            // Human-readable label

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("payment_configs")
}

// ============================================
// INVOICE (Payment tracking)
// ============================================

model Invoice {
  id               String @id @default(uuid())
  invoice_number   String @unique           // INV-20260201-XXXX
  organization_id  String
  organization     Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  plan_id          String
  plan             SubscriptionPlan @relation(fields: [plan_id], references: [id])

  amount           Int                      // rupiah
  status           InvoiceStatus @default(PENDING)
  payment_method   String?                  // manual_transfer | midtrans | etc
  payment_proof_url String?                 // URL bukti transfer
  payment_gateway_id String?                // ID dari payment gateway

  period_start     DateTime?
  period_end       DateTime?

  notes            String? @db.Text         // catatan admin
  paid_at          DateTime?
  verified_by      String?                  // user_id admin yang verifikasi
  expired_at       DateTime?

  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@index([organization_id])
  @@index([status])
  @@map("invoices")
}

enum InvoiceStatus {
  PENDING
  PAID
  VERIFIED
  EXPIRED
  CANCELLED
  REFUNDED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

// ============================================
// USER
// ============================================

model User {
  id              String @id @default(uuid())
  organization_id String
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  email         String
  password_hash String
  name          String
  avatar_url    String?
  phone         String?
  role          UserRole @default(AGENT)

  is_active   Boolean  @default(true)
  is_online   Boolean  @default(false)
  last_seen_at DateTime?
  email_verified_at DateTime?
  invite_token           String?  @unique
  invite_token_expires_at DateTime?

  preferences         Json?
  notification_settings Json?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  refresh_tokens       RefreshToken[]
  team_members         TeamMember[]
  notifications        Notification[]
  activity_logs        ActivityLog[]
  sent_messages        Message[]       @relation("SentByUser")
  assigned_conversations Conversation[] @relation("AssignedToUser")
  conversation_assignments ConversationAssignment[] @relation("AssignedUser")
  assigned_by_assignments  ConversationAssignment[] @relation("AssignedByUser")
  resolved_conversations   Conversation[] @relation("ResolvedByUser")
  assigned_deals       Deal[]          @relation("DealAssignedTo")
  created_broadcasts   Broadcast[]     @relation("BroadcastCreatedBy")
  created_templates    MessageTemplate[] @relation("TemplateCreatedBy")
  created_scheduled_messages ScheduledMessage[] @relation("ScheduledMessageCreatedBy")
  contact_notes              ContactNote[]
  created_tasks              Task[] @relation("TaskCreatedBy")
  assigned_tasks             Task[] @relation("TaskAssignedTo")

  @@unique([organization_id, email])
  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  OWNER
  ADMIN
  SUPERVISOR
  AGENT
}

// ============================================
// REFRESH TOKEN
// ============================================

model RefreshToken {
  id         String @id @default(uuid())
  user_id    String
  user       User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  token_hash  String   @unique
  device_info String?
  ip_address  String?
  expires_at  DateTime
  revoked_at  DateTime?

  created_at DateTime @default(now())

  @@map("refresh_tokens")
}

// ============================================
// TEAM
// ============================================

model Team {
  id              String @id @default(uuid())
  organization_id String
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  name            String
  description     String?
  color           String?
  auto_assign     Boolean       @default(false)
  assign_strategy AssignStrategy @default(ROUND_ROBIN)
  max_open_chats  Int           @default(20)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  members                TeamMember[]
  assigned_conversations Conversation[] @relation("AssignedToTeam")
  conversation_assignments ConversationAssignment[] @relation("AssignedTeam")

  @@unique([organization_id, name])
  @@map("teams")
}

enum AssignStrategy {
  ROUND_ROBIN
  LEAST_BUSY
  MANUAL
}

model TeamMember {
  id        String  @id @default(uuid())
  team_id   String
  team      Team    @relation(fields: [team_id], references: [id], onDelete: Cascade)
  user_id   String
  user      User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  is_leader Boolean  @default(false)
  joined_at DateTime @default(now())

  @@unique([team_id, user_id])
  @@map("team_members")
}

// ============================================
// WA INSTANCE
// ============================================

model WAInstance {
  id              String @id @default(uuid())
  organization_id String
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  wa_instance_id  String
  name            String
  phone_number    String?
  wa_display_name String?
  status          InstanceStatus @default(DISCONNECTED)

  health_score        Int?
  daily_message_count Int @default(0)
  daily_limit         Int @default(50)
  warming_phase       String?

  is_default     Boolean   @default(false)
  last_synced_at DateTime?
  connected_at   DateTime?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  contacts      Contact[]
  conversations Conversation[]
  messages      Message[]
  broadcasts    Broadcast[]
  scheduled_messages ScheduledMessage[]

  @@unique([organization_id, wa_instance_id])
  @@map("wa_instances")
}

enum InstanceStatus {
  CONNECTED
  DISCONNECTED
  CONNECTING
  QR_PENDING
}

// ============================================
// CONTACT
// ============================================

model Contact {
  id              String @id @default(uuid())
  organization_id String
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  instance_id     String?
  instance        WAInstance? @relation(fields: [instance_id], references: [id])

  wa_contact_id String?
  phone_number  String
  name          String?
  email         String?
  avatar_url    String?

  company    String?
  job_title  String?
  address    String?
  city       String?
  notes      String? @db.Text
  source     ContactSource @default(WHATSAPP)
  stage      ContactStage  @default(NEW)

  custom_fields Json?

  is_subscribed    Boolean   @default(true)
  last_message_at  DateTime?
  first_message_at DateTime?
  total_messages   Int       @default(0)
  lead_score       Int       @default(0)

  is_blocked     Boolean @default(false)
  blocked_reason String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  contact_tags  ContactTag[]
  conversations Conversation[]
  broadcast_recipients BroadcastRecipient[]
  scheduled_message_recipients ScheduledMessageRecipient[]
  deals         Deal[]
  contact_notes ContactNote[]
  tasks         Task[]

  @@unique([organization_id, phone_number])
  @@index([organization_id, stage])
  @@index([organization_id, last_message_at])
  @@index([organization_id, lead_score])
  @@index([phone_number])
  @@map("contacts")
}

enum ContactSource {
  WHATSAPP
  MANUAL
  IMPORT
  API
  WEBSITE
}

enum ContactStage {
  NEW
  LEAD
  QUALIFIED
  CUSTOMER
  VIP
  CHURNED
}

// ============================================
// TAG
// ============================================

model Tag {
  id              String @id @default(uuid())
  organization_id String
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  name        String
  color       String?
  description String?

  created_at DateTime @default(now())

  contact_tags ContactTag[]

  @@unique([organization_id, name])
  @@map("tags")
}

model ContactTag {
  contact_id  String
  contact     Contact @relation(fields: [contact_id], references: [id], onDelete: Cascade)
  tag_id      String
  tag         Tag     @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  assigned_at DateTime @default(now())

  @@id([contact_id, tag_id])
  @@map("contact_tags")
}

model ContactNote {
  id         String  @id @default(uuid())
  contact_id String
  contact    Contact @relation(fields: [contact_id], references: [id], onDelete: Cascade)
  user_id    String
  user       User    @relation(fields: [user_id], references: [id])
  content    String  @db.Text

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([contact_id, created_at])
  @@map("contact_notes")
}

// ============================================
// CONVERSATION
// ============================================

model Conversation {
  id              String @id @default(uuid())
  organization_id String
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  instance_id     String
  instance        WAInstance @relation(fields: [instance_id], references: [id])
  contact_id      String
  contact         Contact @relation(fields: [contact_id], references: [id])

  chat_jid String

  status   ConversationStatus @default(OPEN)
  priority Priority           @default(MEDIUM)

  unread_count   Int @default(0)
  total_messages Int @default(0)

  last_message_at        DateTime?
  last_message_preview   String?  @db.VarChar(500)
  last_message_direction MessageDirection?

  assigned_to_user_id String?
  assigned_to_user    User? @relation("AssignedToUser", fields: [assigned_to_user_id], references: [id])
  assigned_to_team_id String?
  assigned_to_team    Team? @relation("AssignedToTeam", fields: [assigned_to_team_id], references: [id])

  resolved_at    DateTime?
  resolved_by_id String?
  resolved_by    User?    @relation("ResolvedByUser", fields: [resolved_by_id], references: [id])

  first_response_at DateTime?
  sla_deadline_at   DateTime?
  sla_breached_at   DateTime?
  sla_warning_sent  Boolean   @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  messages    Message[]
  assignments ConversationAssignment[]
  labels      ConversationLabel[]
  deals       Deal[]
  tasks       Task[]

  @@unique([organization_id, chat_jid, instance_id])
  @@index([organization_id, status, last_message_at])
  @@index([organization_id, assigned_to_user_id])
  @@map("conversations")
}

enum ConversationStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MessageDirection {
  INCOMING
  OUTGOING
}

// ============================================
// MESSAGE
// ============================================

model Message {
  id              String @id @default(uuid())
  organization_id String
  conversation_id String
  conversation    Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  instance_id     String
  instance        WAInstance @relation(fields: [instance_id], references: [id])

  wa_message_id String?

  direction    MessageDirection
  message_type MessageType @default(TEXT)
  content      String?     @db.Text
  caption      String?

  media_url        String?
  media_local_path String?
  media_mime_type  String?
  media_size       Int?
  filename         String?

  latitude         Float?
  longitude        Float?
  location_name    String?
  location_address String?

  status        MessageStatus @default(PENDING)
  error_message String?

  sent_by_user_id   String?
  sent_by_user      User?   @relation("SentByUser", fields: [sent_by_user_id], references: [id])
  is_from_broadcast Boolean @default(false)
  broadcast_id      String?
  is_internal_note  Boolean @default(false)
  is_edited         Boolean  @default(false)
  edited_at         DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([conversation_id, created_at])
  @@index([organization_id, created_at])
  @@index([wa_message_id])
  @@map("messages")
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  LOCATION
  STICKER
  CONTACT_CARD
  REACTION
  POLL
  VIEW_ONCE
  SYSTEM
  OTHER
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
  RECEIVED
  DELETED
}

// ============================================
// CONVERSATION ASSIGNMENT
// ============================================

model ConversationAssignment {
  id              String @id @default(uuid())
  conversation_id String
  conversation    Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  user_id String?
  user    User?   @relation("AssignedUser", fields: [user_id], references: [id])
  team_id String?
  team    Team?   @relation("AssignedTeam", fields: [team_id], references: [id])

  assigned_by_id String?
  assigned_by    User?   @relation("AssignedByUser", fields: [assigned_by_id], references: [id])

  reason        String?
  assigned_at   DateTime @default(now())
  unassigned_at DateTime?
  is_active     Boolean  @default(true)

  @@index([conversation_id, is_active])
  @@map("conversation_assignments")
}

// ============================================
// CONVERSATION LABEL
// ============================================

model ConversationLabel {
  id              String @id @default(uuid())
  conversation_id String
  conversation    Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  label String
  color String?

  @@unique([conversation_id, label])
  @@map("conversation_labels")
}

// ============================================
// MESSAGE TEMPLATE
// ============================================

model MessageTemplate {
  id              String @id @default(uuid())
  organization_id String
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  name       String
  category   String?
  content    String @db.Text
  media_url  String?
  media_type MessageType?

  variables Json?

  is_active     Boolean @default(true)
  usage_count   Int     @default(0)
  created_by_id String?
  created_by    User?   @relation("TemplateCreatedBy", fields: [created_by_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  broadcasts Broadcast[]
  auto_responses AutoResponse[]

  @@unique([organization_id, name])
  @@map("message_templates")
}

// ============================================
// BROADCAST
// ============================================

model Broadcast {
  id              String @id @default(uuid())
  organization_id String
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  instance_id     String
  instance        WAInstance @relation(fields: [instance_id], references: [id])
  template_id     String?
  template        MessageTemplate? @relation(fields: [template_id], references: [id])

  name            String
  message_content String @db.Text
  media_url       String?
  media_type      MessageType?

  status       BroadcastStatus @default(DRAFT)
  scheduled_at DateTime?
  started_at   DateTime?
  completed_at DateTime?

  total_recipients Int @default(0)
  sent_count       Int @default(0)
  delivered_count  Int @default(0)
  read_count       Int @default(0)
  failed_count     Int @default(0)

  delay_min_seconds Int @default(5)
  delay_max_seconds Int @default(15)

  created_by_id String?
  created_by    User?   @relation("BroadcastCreatedBy", fields: [created_by_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  recipients BroadcastRecipient[]

  @@map("broadcasts")
}

enum BroadcastStatus {
  DRAFT
  SCHEDULED
  SENDING
  PAUSED
  COMPLETED
  CANCELLED
  FAILED
}

model BroadcastRecipient {
  id           String @id @default(uuid())
  broadcast_id String
  broadcast    Broadcast @relation(fields: [broadcast_id], references: [id], onDelete: Cascade)
  contact_id   String
  contact      Contact @relation(fields: [contact_id], references: [id])

  phone_number         String
  personalized_message String? @db.Text

  status        MessageStatus @default(PENDING)
  wa_message_id String?
  error_message String?
  sent_at       DateTime?
  delivered_at  DateTime?
  read_at       DateTime?

  @@index([broadcast_id, status])
  @@map("broadcast_recipients")
}

// ============================================
// DEAL / CLOSING (Sales Pipeline)
// ============================================

model Deal {
  id              String @id @default(uuid())
  organization_id String
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  contact_id      String
  contact         Contact @relation(fields: [contact_id], references: [id])
  conversation_id String?
  conversation    Conversation? @relation(fields: [conversation_id], references: [id])

  title       String
  description String? @db.Text
  deal_number String  @unique

  stage    DealStage @default(QUALIFICATION)
  pipeline String    @default("default")

  value           Decimal  @default(0) @db.Decimal(15, 2)
  currency        String   @default("IDR")
  win_probability Int      @default(0)

  assigned_to_id String?
  assigned_to    User?   @relation("DealAssignedTo", fields: [assigned_to_id], references: [id])

  expected_close_date DateTime?
  actual_close_date   DateTime?

  closed_status DealClosedStatus?
  lost_reason   String?
  won_notes     String? @db.Text

  products      Json?
  source        String?
  custom_fields Json?
  is_archived   Boolean @default(false)

  rotten_notified_at DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  activities    DealActivity[]
  tracked_links TrackedLink[]
  receipts      Receipt[]
  tasks         Task[]

  @@index([organization_id, stage])
  @@index([organization_id, assigned_to_id])
  @@index([organization_id, closed_status])
  @@index([organization_id, expected_close_date])
  @@map("deals")
}

enum DealStage {
  QUALIFICATION
  PROPOSAL
  NEGOTIATION
  CLOSING
  WON
  LOST
}

enum DealClosedStatus {
  WON
  LOST
}

model DealActivity {
  id      String @id @default(uuid())
  deal_id String
  deal    Deal   @relation(fields: [deal_id], references: [id], onDelete: Cascade)

  user_id     String?
  type        DealActivityType
  title       String
  description String?
  metadata    Json?

  created_at DateTime @default(now())

  @@index([deal_id, created_at])
  @@map("deal_activities")
}

enum DealActivityType {
  STAGE_CHANGED
  VALUE_CHANGED
  ASSIGNED
  NOTE_ADDED
  PRODUCT_ADDED
  WON
  LOST
  REOPENED
  CREATED
  LINK_CREATED
  LINK_CLICKED
  PAYMENT_RECEIVED
  RECEIPT_SENT
}

// ============================================
// TRACKED LINK
// ============================================

model TrackedLink {
  id              String @id @default(uuid())
  organization_id String
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  deal_id         String
  deal            Deal @relation(fields: [deal_id], references: [id], onDelete: Cascade)
  created_by_id   String

  original_url    String  @db.Text
  tracking_code   String  @unique
  label           String?

  click_count     Int     @default(0)
  is_converted    Boolean @default(false)
  converted_at    DateTime?
  conversion_value Decimal? @db.Decimal(15, 2)
  payment_ref     String?
  metadata        Json?
  expires_at      DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  receipts Receipt[]

  @@index([organization_id, deal_id])
  @@index([tracking_code])
  @@map("tracked_links")
}

// ============================================
// RECEIPT / KWITANSI
// ============================================

model Receipt {
  id              String @id @default(uuid())
  organization_id String
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  deal_id         String?
  deal            Deal? @relation(fields: [deal_id], references: [id], onDelete: SetNull)
  tracked_link_id String?
  tracked_link    TrackedLink? @relation(fields: [tracked_link_id], references: [id], onDelete: SetNull)

  receipt_number  String
  type            String   @default("invoice")
  status          ReceiptStatus @default(DRAFT)

  recipient_name  String
  recipient_phone String?
  recipient_email String?

  items           Json
  subtotal        Decimal  @db.Decimal(15, 2)
  tax_amount      Decimal  @default(0) @db.Decimal(15, 2)
  total_amount    Decimal  @db.Decimal(15, 2)
  currency        String   @default("IDR")

  payment_method  String?
  payment_ref     String?
  notes           String?  @db.Text
  footer_text     String?  @db.Text

  pdf_url         String?
  sent_via_wa     Boolean  @default(false)
  sent_at         DateTime?

  revision_of     String?
  voided_at       DateTime?
  voided_reason   String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([organization_id, receipt_number])
  @@index([organization_id, status])
  @@index([organization_id, deal_id])
  @@map("receipts")
}

enum ReceiptStatus {
  DRAFT
  SENT
  FAILED
  VOIDED
}

// ============================================
// TASK & REMINDER
// ============================================

model Task {
  id              String @id @default(uuid())
  organization_id String
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  title       String
  description String? @db.Text
  type        TaskType @default(OTHER)
  status      TaskStatus @default(TODO)
  priority    Priority @default(MEDIUM)

  due_date    DateTime?
  reminder_at DateTime?
  reminder_sent Boolean @default(false)

  created_by_id String
  created_by    User @relation("TaskCreatedBy", fields: [created_by_id], references: [id])

  assigned_to_id String?
  assigned_to    User? @relation("TaskAssignedTo", fields: [assigned_to_id], references: [id])

  contact_id String?
  contact    Contact? @relation(fields: [contact_id], references: [id], onDelete: SetNull)

  deal_id String?
  deal    Deal? @relation(fields: [deal_id], references: [id], onDelete: SetNull)

  conversation_id String?
  conversation    Conversation? @relation(fields: [conversation_id], references: [id], onDelete: SetNull)

  completed_at DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([organization_id, status])
  @@index([organization_id, assigned_to_id])
  @@index([organization_id, due_date])
  @@index([reminder_at, reminder_sent])
  @@map("tasks")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskType {
  FOLLOW_UP
  CALL
  MEETING
  EMAIL
  OTHER
}

// ============================================
// AUTOMATION
// ============================================

model Automation {
  id              String @id @default(uuid())
  organization_id String
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  name        String
  description String?

  trigger_type   AutomationTrigger
  trigger_config Json?

  action_type   AutomationAction
  action_config Json?

  is_active       Boolean @default(true)
  priority        Int     @default(0)
  execution_count Int     @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("automations")
}

enum AutomationTrigger {
  MESSAGE_RECEIVED
  KEYWORD_MATCH
  FIRST_MESSAGE
  CONTACT_CREATED
  NO_REPLY_TIMEOUT
  BUSINESS_HOURS
}

enum AutomationAction {
  SEND_REPLY
  ASSIGN_TEAM
  ASSIGN_USER
  ADD_TAG
  SET_STAGE
  SEND_NOTIFICATION
  WEBHOOK
}

// ============================================
// NOTIFICATION
// ============================================

model Notification {
  id      String @id @default(uuid())
  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  type    NotificationType
  title   String
  body    String?
  data    Json?

  is_read Boolean   @default(false)
  read_at DateTime?

  created_at DateTime @default(now())

  @@index([user_id, is_read, created_at])
  @@map("notifications")
}

enum NotificationType {
  NEW_MESSAGE
  ASSIGNED
  MENTION
  BROADCAST_COMPLETED
  INSTANCE_DISCONNECTED
  SLA_WARNING
  SLA_BREACHED
  TASK_DUE
  TASK_ASSIGNED
  DEAL_ROTTEN
  SYSTEM
}

// ============================================
// ACTIVITY LOG (Audit Trail)
// ============================================

model ActivityLog {
  id              String @id @default(uuid())
  organization_id String
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  user_id    String?
  user       User?   @relation(fields: [user_id], references: [id])
  contact_id String?

  action      String
  entity_type String
  entity_id   String?

  details    Json?
  ip_address String?

  created_at DateTime @default(now())

  @@index([organization_id, created_at])
  @@index([entity_type, entity_id])
  @@map("activity_logs")
}

// ============================================
// SCHEDULED MESSAGE (Recurring Reminders)
// ============================================

model ScheduledMessage {
  id              String @id @default(uuid())
  organization_id String
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  instance_id     String
  instance        WAInstance @relation(fields: [instance_id], references: [id])

  name            String
  message_content String @db.Text
  media_url       String?
  media_type      MessageType?

  // Cron expression for scheduling (e.g. "30 4 * * *" = every day 04:30)
  cron_expression String
  timezone        String @default("Asia/Jakarta")

  // Conditional skip: JSON array of days to skip (0=Sun,1=Mon,...6=Sat)
  // e.g. [5,6] = skip Friday & Saturday
  skip_days       Json?

  // Auto-add recipients by tag IDs (JSON array of tag UUIDs)
  // At execution time, all contacts with these tags are included
  recipient_tag_ids Json?

  // Delay between messages to avoid WA rate limit
  delay_min_seconds Int @default(3)
  delay_max_seconds Int @default(10)

  is_active       Boolean @default(true)
  bullmq_job_key  String?

  // Stats
  total_sent       Int @default(0)
  total_failed     Int @default(0)
  last_executed_at DateTime?
  next_execution_at DateTime?

  created_by_id String?
  created_by    User? @relation("ScheduledMessageCreatedBy", fields: [created_by_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  recipients ScheduledMessageRecipient[]
  logs       ScheduledMessageLog[]

  @@index([organization_id, is_active])
  @@map("scheduled_messages")
}

model ScheduledMessageRecipient {
  id                   String @id @default(uuid())
  scheduled_message_id String
  scheduled_message    ScheduledMessage @relation(fields: [scheduled_message_id], references: [id], onDelete: Cascade)
  contact_id           String
  contact              Contact @relation(fields: [contact_id], references: [id])

  phone_number String
  is_active    Boolean @default(true)

  added_at DateTime @default(now())

  @@unique([scheduled_message_id, contact_id])
  @@map("scheduled_message_recipients")
}

model ScheduledMessageLog {
  id                   String @id @default(uuid())
  scheduled_message_id String
  scheduled_message    ScheduledMessage @relation(fields: [scheduled_message_id], references: [id], onDelete: Cascade)

  executed_at     DateTime @default(now())
  total_targets   Int @default(0)
  sent_count      Int @default(0)
  failed_count    Int @default(0)
  skipped_reason  String?

  details Json?

  @@index([scheduled_message_id, executed_at])
  @@map("scheduled_message_logs")
}

// ============================================
// WEBHOOK CONFIG
// ============================================

model WebhookConfig {
  id              String @id @default(uuid())
  organization_id String
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  name            String
  webhook_url     String
  webhook_secret  String?
  events          Json?
  wa_instance_id  String?

  is_active        Boolean   @default(true)
  last_triggered_at DateTime?
  failure_count    Int       @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([organization_id])
  @@map("webhook_configs")
}

// ============================================
// AUTO RESPONSE
// ============================================

enum AutoResponseTrigger {
  NEW_CHAT
  OUTSIDE_HOURS
}

model AutoResponse {
  id              String @id @default(uuid())
  organization_id String
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  trigger      AutoResponseTrigger
  template_id  String
  template     MessageTemplate @relation(fields: [template_id], references: [id])

  // Business hours config (for OUTSIDE_HOURS trigger)
  business_hour_start String?  // e.g. "08:00"
  business_hour_end   String?  // e.g. "17:00"
  business_days       Json?    // e.g. [1,2,3,4,5] (Mon-Fri)
  timezone            String   @default("Asia/Jakarta")

  // Cooldown: don't send the same auto-response to the same contact within N minutes
  cooldown_minutes Int @default(60)

  is_active Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([organization_id, trigger])
  @@map("auto_responses")
}

// ============================================
// QUICK REPLY (Canned Responses)
// ============================================

model QuickReply {
  id              String @id @default(uuid())
  organization_id String
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  shortcut    String        // e.g. "salam", "harga", "alamat"
  title       String
  content     String @db.Text
  category    String?
  media_url   String?
  media_type  MessageType?

  usage_count Int     @default(0)
  is_active   Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([organization_id, shortcut])
  @@index([organization_id, is_active])
  @@map("quick_replies")
}

// ============================================
// CSAT (Customer Satisfaction)
// ============================================

model CSATResponse {
  id              String @id @default(uuid())
  organization_id String
  conversation_id String
  contact_id      String

  rating       Int        // 1-5
  feedback     String?    @db.Text
  resolved_by_id String?
  responded_at DateTime   @default(now())

  created_at DateTime @default(now())

  @@index([organization_id, created_at])
  @@index([conversation_id])
  @@map("csat_responses")
}

model CSATSetting {
  id              String @id @default(uuid())
  organization_id String @unique
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  is_enabled       Boolean @default(false)
  message_template String  @db.Text
  delay_minutes    Int     @default(5)  // delay after resolve before sending

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("csat_settings")
}

// ============================================
// SLA SETTING (Per Organization)
// ============================================

model SlaSetting {
  id              String @id @default(uuid())
  organization_id String @unique
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  is_enabled              Boolean @default(false)
  first_response_minutes  Int     @default(30)   // SLA for first reply
  resolution_minutes      Int     @default(1440) // SLA for full resolution (24h)
  escalation_enabled      Boolean @default(true)
  warning_threshold_pct   Int     @default(80)   // warn at 80% of SLA time

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("sla_settings")
}

// ============================================
// SAVED FILTER (Custom Views)
// ============================================

model SavedFilter {
  id              String @id @default(uuid())
  organization_id String
  user_id         String

  name       String
  entity     String         // "conversation" | "contact" | "deal"
  filters    Json           // the filter criteria
  is_default Boolean @default(false)
  sort_order Int     @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([user_id, entity])
  @@map("saved_filters")
}

// ============================================
// HOLIDAY CALENDAR
// ============================================

model Holiday {
  id              String @id @default(uuid())
  organization_id String
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  name       String
  date       DateTime @db.Date
  is_recurring Boolean @default(false) // recur every year

  created_at DateTime @default(now())

  @@unique([organization_id, date])
  @@map("holidays")
}

// ============================================
// INTERNAL CHAT (Agent-to-Agent)
// ============================================

model InternalChat {
  id String @id @default(uuid())
  organization_id String
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  // null = group chat, otherwise DM between two users
  name        String?
  is_group    Boolean @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  participants InternalChatParticipant[]
  messages     InternalMessage[]

  @@map("internal_chats")
}

model InternalChatParticipant {
  id      String @id @default(uuid())
  chat_id String
  chat    InternalChat @relation(fields: [chat_id], references: [id], onDelete: Cascade)
  user_id String

  joined_at DateTime @default(now())
  last_read_at DateTime?

  @@unique([chat_id, user_id])
  @@map("internal_chat_participants")
}

model InternalMessage {
  id      String @id @default(uuid())
  chat_id String
  chat    InternalChat @relation(fields: [chat_id], references: [id], onDelete: Cascade)
  sender_id String

  content    String @db.Text
  media_url  String?
  media_type MessageType?

  created_at DateTime @default(now())

  @@index([chat_id, created_at])
  @@map("internal_messages")
}
