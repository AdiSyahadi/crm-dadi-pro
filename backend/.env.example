# ===== APP =====
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# ===== DATABASE (MySQL via XAMPP) =====
DATABASE_URL="mysql://root:@localhost:3306/crm_dadi"

# ===== REDIS =====
REDIS_URL="redis://localhost:6379"

# ===== JWT =====
JWT_SECRET=change-this-to-random-string
JWT_REFRESH_SECRET=change-this-to-another-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===== WA API (Teman) =====
WA_API_BASE_URL=https://your-friend-wa-api.com
WA_API_KEY=your-wa-api-key
WA_ORGANIZATION_ID=your-wa-org-id

# ===== WEBHOOK =====
WEBHOOK_SECRET=your-webhook-secret

# ===== UPLOAD =====
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
